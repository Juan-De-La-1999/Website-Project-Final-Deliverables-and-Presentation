current_status <- data.frame(
Metric = c("Users", "Sessions", "Page Views", "Engagement Rate"),
Status = c("Tracking Active", "Tracking Active", "Tracking Active", "Tracking Active")
)
knitr::kable(current_status)
months <- c("Month 1", "Month 2", "Month 3", "Month 4", "Month 5", "Month 6")
projected_users <- c(25, 55, 90, 135, 185, 245)
projected_sessions <- c(35, 75, 125, 180, 245, 320)
projected_pageviews <- c(80, 170, 290, 430, 600, 780)
forecast <- data.frame(
Month = months,
Projected_Users = projected_users,
Projected_Sessions = projected_sessions,
Projected_Pageviews = projected_pageviews
)
knitr::kable(forecast)
months <- c("Month 1", "Month 2", "Month 3", "Month 4", "Month 5", "Month 6")
projected_users <- c(25, 55, 90, 135, 185, 245)
projected_sessions <- c(35, 75, 125, 180, 245, 320)
projected_pageviews <- c(80, 170, 290, 430, 600, 780)
forecast <- data.frame(
Month = months,
Projected_Users = projected_users,
Projected_Sessions = projected_sessions,
Projected_Pageviews = projected_pageviews
)
knitr::kable(forecast)
plot(
projected_users,
type = "o",
xaxt = "n",
xlab = "Month",
ylab = "Projected Users",
main = "Projected Website Traffic Growth"
)
axis(1, at = 1:6, labels = months)
grid()
months <- c("Month 1", "Month 2", "Month 3", "Month 4", "Month 5", "Month 6")
users <- c(25, 55, 90, 135, 185, 245)
plot(
users,
type = "b",
pch = 19,
xaxt = "n",
xlab = "Month",
ylab = "Projected Users",
main = "Projected Website Traffic Growth"
)
axis(1, at = 1:6, labels = months)
grid()
users <- c(25, 55, 90, 135, 185, 245)
sessions <- c(35, 75, 125, 180, 245, 320)
pageviews <- c(80, 170, 290, 430, 600, 780)
plot(users, type="o", xaxt="n", ylab="Count", xlab="Month",
main="Projected Growth (Users, Sessions, Page Views)")
lines(sessions, type="o", lty=2)
lines(pageviews, type="o", lty=3)
axis(1, at=1:6, labels=c("M1","M2","M3","M4","M5","M6"))
legend("topleft",
legend=c("Users","Sessions","Page Views"),
lty=c(1,2,3))
quarto render
